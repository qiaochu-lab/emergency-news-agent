# Model provider
EI_PROVIDER=openai_compatible

# OpenAI-compatible chat completions endpoint
EI_API_BASE=https://api.deepseek.com/v1/chat/completions

# Replace with your own key. Do not commit real secrets.
EI_API_KEY=your_llm_api_key_here

# Recommended text-first model for report generation
EI_MODEL=deepseek-chat

# X API credentials
EI_X_BEARER_TOKEN=your_x_bearer_token_here
EI_X_API_KEY=your_x_api_key_here
EI_X_API_SECRET=your_x_api_secret_here

# Optional X user-context credentials
EI_X_CLIENT_ID=
EI_X_CLIENT_SECRET=
EI_X_ACCESS_TOKEN=
EI_X_ACCESS_TOKEN_SECRET=

# Pipeline behavior
EI_ANALYSIS_MIN_SCORE=6.0
EI_COLLECT_TIMEOUT_SECONDS=20
EI_ENRICH_TIMEOUT_SECONDS=15
EI_SCHEDULE_WEEKDAY=MON
EI_SCHEDULE_HOUR=9
EI_TIMEZONE=Asia/Shanghai
